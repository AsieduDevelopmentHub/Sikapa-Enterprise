# ============================================================================
# SIKAPA ENTERPRISE — STAGING backend (.env.staging.example)
# ============================================================================
# Copy to backend/.env.staging for local runs against staging infra, OR set
# these in Render Dashboard on the sikapa-backend-staging service only.
#
# NEVER use production DATABASE_URL, SECRET_KEY, or sk_live_ Paystack keys here.
# See: docs/deployment/staging-environment.md
# ============================================================================

ENVIRONMENT=staging
DEBUG=false
HTTPS_ENABLED=false

# Dedicated staging Postgres (Supabase project or Render Postgres — not production)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Staging-only secrets (generate new values — do not copy from production)
SECRET_KEY=
TOTP_ENCRYPTION_KEY=

# Staging storefront (Vercel staging project URL)
FRONTEND_URL=https://sikapa-staging.vercel.app
CORS_ORIGINS=https://sikapa-staging.vercel.app
CORS_ALLOW_CREDENTIALS=true

# Paystack TEST keys only
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS

# Staging Supabase project (separate bucket from production)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET_NAME=product-images-staging

UPLOAD_SERVE_LOCAL=false
UPLOAD_ALLOW_LOCAL_FALLBACK=false
DISABLE_OPENAPI=false

# Optional: block deploy if DATABASE_URL equals production (paste prod URL)
# STAGING_FORBIDDEN_DATABASE_URL=postgresql://...

# Email — off or Resend test mode
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=staging@yourdomain.com

REDIS_URL=
API_RATE_LIMIT_ENABLED=true

# Google OAuth (optional) — use staging redirect URI on Google Console
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://sikapa-backend-staging.onrender.com/api/v1/auth/google/callback

SENTRY_DSN=
ALLOWED_HOSTS=sikapa-backend-staging.onrender.com
