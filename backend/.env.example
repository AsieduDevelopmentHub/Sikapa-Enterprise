# ============================================================================
# SIKAPA ENTERPRISE - Backend Environment Configuration (.env.example)
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in actual values for your environment
# 3. NEVER commit .env with real secrets to version control
# 4. Use a secrets manager in production (AWS Secrets Manager, Render environment, etc.)
# ============================================================================

# ============ SECURITY (CRITICAL - MUST SET IN PRODUCTION) ============
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Use ONLY strong, randomly-generated keys (minimum 32 bytes recommended)
SECRET_KEY=your-secret-key-here-change-in-production

# Environment designation (impacts security validation)
ENVIRONMENT=development  # development | staging | production

# Debug mode (disable in production)
DEBUG=false

# HTTPS/TLS Configuration
HTTPS_ENABLED=false  # true only if THIS process terminates TLS
SSL_CERT_PATH=certs/server.crt
SSL_KEY_PATH=certs/server.key
HTTPS_PORT=8443
HTTP_PORT=8000

# ============ DATABASE ============
# Local: sqlite:///./db/sikapa.db
# Production: postgresql://user:password@host/dbname (Supabase, AWS RDS, etc.)
DATABASE_URL=sqlite:///./db/sikapa.db

# Optional: separate Alembic migration URL (for offline migrations)
# ALEMBIC_DATABASE_URL=sqlite:///./db/sikapa.db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600


# ============ CORS & API SECURITY ============
# Frontend origins that can call this API (comma-separated, no spaces)
# Examples: http://localhost:3000,https://app.example.com,https://staging.example.com
CORS_ORIGINS=http://localhost:3000

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# Optional: regex pattern for dynamic origins (e.g., Vercel preview deployments)
# Example: CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=

# Frontend base URL (for redirects and email links)
FRONTEND_URL=http://localhost:3000

# Restrict specific HTTP headers
# Default allows all; set to specific headers for stricter policy
# CORS_ALLOWED_HEADERS=Content-Type,Authorization


# ============ AUTHENTICATION & TOKENS ============
# JWT token expiration (minutes for access token, days for refresh)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting for auth attempts
AUTH_ATTEMPT_LIMIT=5
AUTH_ATTEMPT_WINDOW_MINUTES=15

# Google OAuth (optional — “Continue with Google” on /account)
# How to get keys:
# 1) https://console.cloud.google.com/ → create or select a project
# 2) APIs & Services → OAuth consent screen — configure (External for public; add test users in Testing)
# 3) APIs & Services → Credentials → Create credentials → OAuth client ID → Application type: Web application
# 4) Authorized JavaScript origins: the SPA only (where the browser loads the app), e.g.:
#    http://localhost:3000
#    https://your-production-site.com
#    (Do NOT put the API URL here unless the API serves the HTML app.)
# 5) Authorized redirect URIs: the BACKEND callback that receives the ?code= from Google — must match
#    GOOGLE_OAUTH_REDIRECT_URI below character-for-character (scheme, host, port, path; no trailing slash).
#    Local API default:
#    http://localhost:8000/api/v1/auth/google/callback
#    Deployed example (your real API host):
#    https://api.yourdomain.com/api/v1/auth/google/callback

# 6) Copy Client ID and Client Secret into the variables below. FRONTEND_URL must match your SPA URL.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Paystack — use LIVE keys on production (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=your-paystack-secret-key-here
PAYSTACK_PUBLIC_KEY=your-paystack-public-key-here
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS
# Optional hardening: only accept webhooks from listed source IPs (comma-separated).
# Leave empty in local development.
PAYSTACK_WEBHOOK_IP_ALLOWLIST=

# Supabase (Storage + Postgres URL for production). tools/supabase_wipe_data.py empties STORAGE when
# SUPABASE_URL + SUPABASE_SERVICE_KEY are set; destructive DB wipe requires SUPABASE_WIPE_CONFIRM=DELETE_ALL_DATA.
# Optional: SUPABASE_STORAGE_BUCKET_NAMES=product-images,other-bucket

# Uploaded images (admin): max bytes per file (default 5242880 = 5 MiB)
IMAGE_UPLOAD_MAX_BYTES=5242880
# If Supabase upload fails: true = fall back to local backend/uploads (dev-friendly); false = HTTP 503 (production CDN-only)
UPLOAD_ALLOW_LOCAL_FALLBACK=true
# Serve locally stored files at /uploads — set false when all URLs are HTTPS CDN/Supabase and disk is unused
UPLOAD_SERVE_LOCAL=true

# Disable Swagger/ReDoc/OpenAPI JSON (also auto-disabled when ENVIRONMENT=production)
DISABLE_OPENAPI=false

# Verified subscribers receive optional product launch / price-drop emails after admin catalog changes (runs after HTTP response).
NEWSLETTER_PRODUCT_ALERTS_ENABLED=true
NEWSLETTER_MAX_RECIPIENTS=1000

# API burst guard for high-traffic endpoints (per-IP, per-second, in-memory).
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_PATH_PREFIXES=/api/v1/admin,/api/v1/orders,/api/v1/payments

# Synthetic Paystack customer email when the user has no inbox (no mail is sent to this domain).
# Use a valid domain so payment gateways accept the address format.
PLACEHOLDER_EMAIL_DOMAIN=payments-internal.sikapa.com


# ============ CACHING & ASYNC TASKS ============
# Redis configuration for cache, rate limiting, and Celery broker
# Format: redis://[:password]@host:port/db
REDIS_URL=redis://localhost:6379/0

# Celery task queue URLs (can share REDIS_URL or use separate DBs)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# ============ TOTP (2FA) ENCRYPTION ============
# MUST SET IN PRODUCTION to encrypt TOTP secrets before database storage.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=
