# -----------------------------------------------------------------------------
# Production: set ENVIRONMENT=production (or PRODUCTION=true) and a strong SECRET_KEY (>=32 chars).
# The API will refuse to start if the secret is missing, too short, or the dev default when in production mode.
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# Database (use PostgreSQL in production; sqlite is for local/dev only)
DATABASE_URL=sqlite:///./db/sikapa.db

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here

# HTTPS Configuration (set true only when THIS process terminates TLS; often false behind Render/nginx TLS)
HTTPS_ENABLED=false
SSL_CERT_PATH=certs/server.crt
SSL_KEY_PATH=certs/server.key
HTTPS_PORT=8443
HTTP_PORT=8000

# CORS Settings (for frontend integration)
# Include every browser Origin that calls this API (no spaces around commas). Add your deployed
# frontend URL(s), e.g. https://your-app.onrender.com or https://your-app.vercel.app
CORS_ORIGINS=https://localhost:3000,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
# Optional: regex for preview deploys (Origin must still match). Example:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Email Configuration
EMAIL_ENABLED=true
DEFAULT_FROM_EMAIL="Email Sender <yourname@your-domain.com>"
# No trailing slash. Password reset + OAuth final redirect target — must be your Next.js site (SPA),
# never the API host. Example Render static/web service: https://sikapa-web.onrender.com
FRONTEND_URL=https://your-frontend-url.example
RESEND_API_KEY=your-resend-api-key-here
# Optional: HTTPS URL to your logo (emails + PDF invoice header). Square or wide PNG/SVG hosted on a public URL.
EMAIL_LOGO_URL=
# Base URL for product images when stored as paths like /uploads/... (must be publicly reachable for email clients).
# Example: https://api.yourdomain.com
EMAIL_IMAGE_BASE_URL=

# JWT Configuration (algorithm is HS256 in code unless you change security.py)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional — “Continue with Google” on /account)
# How to get keys:
# 1) https://console.cloud.google.com/ → create or select a project
# 2) APIs & Services → OAuth consent screen — configure (External for public; add test users in Testing)
# 3) APIs & Services → Credentials → Create credentials → OAuth client ID → Application type: Web application
# 4) Authorized JavaScript origins: the SPA only (where the browser loads the app), e.g.:
#    http://localhost:3000
#    https://your-production-site.com
#    (Do NOT put the API URL here unless the API serves the HTML app.)
# 5) Authorized redirect URIs: the BACKEND callback that receives the ?code= from Google — must match
#    GOOGLE_OAUTH_REDIRECT_URI below character-for-character (scheme, host, port, path; no trailing slash).
#    Local API default:
#    http://localhost:8000/api/v1/auth/google/callback
#    Deployed example (your real API host):
#    https://api.yourdomain.com/api/v1/auth/google/callback
# Error 400 redirect_uri_mismatch: the URI in Google Console ≠ GOOGLE_OAUTH_REDIRECT_URI, or you used the
# frontend URL here by mistake — Google always redirects to this API path, not to /account on Next.js.
#
# Render.com: the API URL is always https://<your-service-name>.onrender.com — there is no hostname like
# "sikapa-onrender.com". Copy the exact URL from the Render dashboard (HTTPS). DNS_PROBE_FINISHED_NXDOMAIN
# on login almost always means GOOGLE_OAUTH_REDIRECT_URI or Google Console used a misspelled/nonexistent host.
# 6) Copy Client ID and Client Secret into the variables below. FRONTEND_URL must match your SPA URL.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Paystack — use LIVE keys on production (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=your-paystack-secret-key-here
PAYSTACK_PUBLIC_KEY=your-paystack-public-key-here
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS
# Optional hardening: only accept webhooks from listed source IPs (comma-separated).
# Leave empty in local development.
PAYSTACK_WEBHOOK_IP_ALLOWLIST=

# Uploaded images (admin): max bytes per file (default 5242880 = 5 MiB)
IMAGE_UPLOAD_MAX_BYTES=5242880
# If Supabase upload fails: true = fall back to local backend/uploads (dev-friendly); false = HTTP 503 (production CDN-only)
UPLOAD_ALLOW_LOCAL_FALLBACK=true
# Serve locally stored files at /uploads — set false when all URLs are HTTPS CDN/Supabase and disk is unused
UPLOAD_SERVE_LOCAL=true

# Disable Swagger/ReDoc/OpenAPI JSON (also auto-disabled when ENVIRONMENT=production)
DISABLE_OPENAPI=false

# Verified subscribers receive optional product launch / price-drop emails after admin catalog changes (runs after HTTP response).
NEWSLETTER_PRODUCT_ALERTS_ENABLED=true
NEWSLETTER_MAX_RECIPIENTS=1000

# API burst guard for high-traffic endpoints (per-IP, per-second, in-memory).
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_PATH_PREFIXES=/api/v1/admin,/api/v1/orders,/api/v1/payments

# Synthetic Paystack customer email when the user has no inbox (no mail is sent to this domain).
# Use a valid domain so payment gateways accept the address format.
PLACEHOLDER_EMAIL_DOMAIN=payments-internal.sikapa.com
