# ============================================================================
# SIKAPA ENTERPRISE - Frontend Environment Configuration (.env.local.example)
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in actual values for your environment
# 3. NEVER commit .env.local with secrets to version control
# 4. All NEXT_PUBLIC_* variables are embedded at build time in the browser
# ============================================================================

# ============ API CONFIGURATION ============
# Backend API base URL (include /api and version prefix)
# Local: http://localhost:8000/api
# Production: https://api.example.com/api
# DO NOT include trailing slash
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# API request timeout (milliseconds)
# NEXT_PUBLIC_API_TIMEOUT=30000


# ============ AUTHENTICATION ============
# Google OAuth Client ID (matches GOOGLE_OAUTH_CLIENT_ID in backend)
# Get from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OAuth redirect callback (handled by Next.js /api/auth/google route)
# Don't change this; it's internal to the frontend
# NEXT_PUBLIC_OAUTH_REDIRECT_URI=/api/auth/google/callback


# ============ PAYMENT GATEWAY ============
# Paystack public key (used for client-side payment initialization)
# Get from: https://dashboard.paystack.com/#/settings/developer
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Payment currency (must match backend PAYSTACK_CURRENCY)
# NEXT_PUBLIC_PAYSTACK_CURRENCY=GHS


# ============ SUPABASE (if using Supabase authentication/storage) ============
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ============ ANALYTICS & MONITORING ============
# Google Analytics Tracking ID (optional)
# NEXT_PUBLIC_GA_ID=

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=


# ============ FEATURE FLAGS & UI ============
# Enable/disable features in UI
# NEXT_PUBLIC_ENABLE_2FA=true
# NEXT_PUBLIC_ENABLE_WISHLIST=true
# NEXT_PUBLIC_ENABLE_REVIEWS=true
# NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# Brand colors and theming (optional - if implementing CSS-in-JS)
# NEXT_PUBLIC_BRAND_COLOR=#000000
# NEXT_PUBLIC_ACCENT_COLOR=#333333


# ============ SOCIAL & CONTACT ============
# Social media links (optional, for footer/contact)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sikapa
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/sikapa
# NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/sikapa
# NEXT_PUBLIC_SOCIAL_WHATSAPP=+233XXXXXXXXXX

# Contact information
# NEXT_PUBLIC_SUPPORT_EMAIL=support@sikapa.com
# NEXT_PUBLIC_SALES_PHONE=+233XXXXXXXXXX


# ============ ENVIRONMENT DESIGNATION ============
# For conditional rendering and API behavior
# NODE_ENV=development  # development | production (automatically set by Next.js)

# Custom environment label (dev/staging/prod)
# NEXT_PUBLIC_ENVIRONMENT=development
