# ============================================================================
# SIKAPA ENTERPRISE — STAGING frontend (.env.staging.example)
# ============================================================================
# For Vercel: create project "sikapa-staging" (or use Preview env) and set these
# under Settings → Environment Variables for the dev/staging branch.
#
# For local testing against staging API:
#   copy to frontend/.env.staging.local and run: npm run dev
#   (load with: dotenv -e .env.staging.local — or merge into .env.local manually)
#
# See: docs/deployment/staging-environment.md
# ============================================================================

# Staging Render API (must end with /api/v1)
NEXT_PUBLIC_API_URL=https://sikapa-backend-staging.onrender.com/api/v1

# Staging storefront canonical URL (Vercel staging project)
NEXT_PUBLIC_SITE_URL=https://sikapa-staging.vercel.app

# Must match backend SECRET_KEY on staging Render service (server-only, not NEXT_PUBLIC_)
SECRET_KEY=

# Observability (optional — separate Sentry project or environment)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2

# Google OAuth button (when backend OAuth is configured)
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# GA4 (same property as production, or a separate staging property)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8HNY0MFRGT
