# Local development — FastAPI v1 prefix (see backend app.main)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional: public site origin for default /terms, /privacy, /faq links (e.g. https://sikapa.auralenx.com)
# NEXT_PUBLIC_SITE_URL=

# Optional: override legal links (default is in-app /terms, /privacy, /faq)
# NEXT_PUBLIC_TERMS_URL=
# NEXT_PUBLIC_PRIVACY_URL=
# NEXT_PUBLIC_FAQ_URL=

# Optional: WhatsApp help link for home banners & CTAs (e.g. https://wa.me/233XXXXXXXXX?text=Hi%20Sikapa)
# NEXT_PUBLIC_WHATSAPP_HELP_URL=

# Floating WhatsApp button (E.164 digits only, no +). Default in app: 233531558216
# NEXT_PUBLIC_WHATSAPP_E164=233531558216

# Optional admin host lock for /system (middleware enforces host when set).
# Example: admin.sikapa.com
# NEXT_PUBLIC_ADMIN_HOST=

# Production / preview deployment — set this in Vercel as an environment variable instead of committing it
# NEXT_PUBLIC_API_URL=https://your-production-backend-url.com/api
