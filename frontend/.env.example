# Local development — must point at the SAME backend the admin portal uses.
# Production (Vercel): set to your Render API, e.g. https://sikapa-backend.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google OAuth: hide the “Continue with Google” button without redeploying backend (optional).
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Public site origin. REQUIRED on Vercel production — sitemap, canonical URLs, OG tags.
# Example: https://sikapa.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev: default skips next/image optimization so remote Supabase/storage URLs load in the browser (avoids optimizer 504 when upstream is slow). Set to 0 to use the optimizer.
# NEXT_PUBLIC_IMAGE_DEV_UNOPTIMIZED=0

# Optional: additional HTTPS hostnames for next/image (comma-separated, no protocol).
# Production Supabase Storage (if not using default **.supabase.co pattern in next.config):
# NEXT_PUBLIC_IMAGE_CDN_HOSTS=pqfowptaguuxhujvclvr.supabase.co

# Optional: override legal links (default is in-app /terms, /privacy, /faq)
# NEXT_PUBLIC_TERMS_URL=
# NEXT_PUBLIC_PRIVACY_URL=
# NEXT_PUBLIC_FAQ_URL=

# Optional: WhatsApp help link for home banners & CTAs (e.g. https://wa.me/233XXXXXXXXX?text=Hi%20Sikapa)
# NEXT_PUBLIC_WHATSAPP_HELP_URL=

# Floating WhatsApp button (E.164 digits only, no +). Default in app: 233531558216
# NEXT_PUBLIC_WHATSAPP_E164=233531558216

# Store location map embed (help/contact page)
# Example (Accra): 5.6037 and -0.1870
# NEXT_PUBLIC_STORE_LAT=5.6037
# NEXT_PUBLIC_STORE_LNG=-0.1870
# Optional:
# NEXT_PUBLIC_STORE_MAP_ZOOM=15
# NEXT_PUBLIC_STORE_LABEL=Sikapa Store

# Optional admin host lock for /system (middleware enforces host when set).
# Example: admin.sikapa.com
# NEXT_PUBLIC_ADMIN_HOST=

# Production / preview — must include /api/v1 (same prefix as FastAPI mount). Use your live API host.
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Show the EU/EEA cookie bar in all environments (for testing). On Vercel, country is taken from x-vercel-ip-country.
# NEXT_PUBLIC_FORCE_COOKIE_BANNER=false

# ============ Maintenance mode (frontend gate) ============
# When true, all storefront paths are rewritten to /maintenance until disabled.
# Independent of the API gate (MAINTENANCE_MODE on the backend); flip both for a
# coordinated outage, or only this one for a marketing-style downtime that
# leaves the API live.
# NEXT_PUBLIC_MAINTENANCE_MODE=false
# Retry-After header value (seconds) returned by the gate. CDNs honour this.
# NEXT_PUBLIC_MAINTENANCE_RETRY_AFTER_SECONDS=300
# Operator bypass token. Edge-runtime env (NOT exposed to the browser bundle).
# Visit `https://<site>/?bypass=<token>` once to set the bypass cookie.
# MAINTENANCE_BYPASS_TOKEN=

# ============ Session cookie / admin gate (server-only — NOT in browser bundle) ============
# Must match backend SECRET_KEY exactly so /api/auth/session and the admin proxy gate
# can verify JWT signatures. Required on Vercel production.
# SECRET_KEY=

# ============ Observability (optional) ============
# Backend: SENTRY_DSN on Render. Frontend: set on Vercel (server + client).
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ============ Analytics (GA4 + Consent Mode) ============
# Set on Vercel Production for sikapa.auralenx.com (and Preview/staging if needed).
# Tag loads in <head>; events fire after the user accepts analytics cookies.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8HNY0MFRGT
