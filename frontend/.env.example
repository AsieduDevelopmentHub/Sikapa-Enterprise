# Local development — FastAPI v1 prefix (see backend app.main)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google OAuth: hide the “Continue with Google” button without redeploying backend (optional).
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Public site origin. REQUIRED in production so sitemap.xml, robots.txt, canonical URLs,
# Open Graph previews, and Twitter cards resolve correctly (same URL must match where users land).
# Example: https://sikapa.com
# NEXT_PUBLIC_SITE_URL=

# Dev: default skips next/image optimization so remote Supabase/storage URLs load in the browser (avoids optimizer 504 when upstream is slow). Set to 0 to use the optimizer.
# NEXT_PUBLIC_IMAGE_DEV_UNOPTIMIZED=0

# Optional: additional HTTPS hostnames that should be whitelisted for next/image optimisation.
# Comma-separated, no protocol, wildcard "*" allowed for the first label.
# Example: cdn.sikapa.com,*.cdn.sikapa.com
# NEXT_PUBLIC_IMAGE_CDN_HOSTS=

# Optional: override legal links (default is in-app /terms, /privacy, /faq)
# NEXT_PUBLIC_TERMS_URL=
# NEXT_PUBLIC_PRIVACY_URL=
# NEXT_PUBLIC_FAQ_URL=

# Optional: WhatsApp help link for home banners & CTAs (e.g. https://wa.me/233XXXXXXXXX?text=Hi%20Sikapa)
# NEXT_PUBLIC_WHATSAPP_HELP_URL=

# Floating WhatsApp button (E.164 digits only, no +). Default in app: 233531558216
# NEXT_PUBLIC_WHATSAPP_E164=233531558216

# Store location map embed (help/contact page)
# Example (Accra): 5.6037 and -0.1870
# NEXT_PUBLIC_STORE_LAT=5.6037
# NEXT_PUBLIC_STORE_LNG=-0.1870
# Optional:
# NEXT_PUBLIC_STORE_MAP_ZOOM=15
# NEXT_PUBLIC_STORE_LABEL=Sikapa Store

# Optional admin host lock for /system (middleware enforces host when set).
# Example: admin.sikapa.com
# NEXT_PUBLIC_ADMIN_HOST=

# Production / preview — must include /api/v1 (same prefix as FastAPI mount). Use your live API host.
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Show the EU/EEA cookie bar in all environments (for testing). On Vercel, country is taken from x-vercel-ip-country.
# NEXT_PUBLIC_FORCE_COOKIE_BANNER=false
