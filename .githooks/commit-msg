#!/bin/sh
# Final pass after tooling may append trailers (e.g. Cursor Co-authored-by).
# Enable in this repo: git config core.hooksPath .githooks
MSG_FILE="$1"
[ -n "$MSG_FILE" ] && [ -f "$MSG_FILE" ] || exit 0
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON=python3
command -v python3 >/dev/null 2>&1 || PYTHON=python
command -v "$PYTHON" >/dev/null 2>&1 || exit 0
"$PYTHON" "$HOOK_DIR/strip_commit_trailers.py" "$MSG_FILE" || exit 0
